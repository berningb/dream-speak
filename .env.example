# Copy this file to `.env` in the project root (Vite loads it automatically).
# Restart `npm run dev` after changing values.
#
# Security: names starting with VITE_ are embedded in the browser bundle.
# Only put public Firebase config and API keys you accept exposing to clients.

# --- Firebase (required) ---
# Firebase Console → Project settings → General → Your apps → Web app.
# Copy apiKey, authDomain, and appId from the SDK snippet (same project as this repo: dream-speak).
# auth/invalid-api-key: wrong key, restricted API key in Google Cloud, or dev server not restarted after .env edits.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_APP_ID=

# --- AI: DeepSeek (required for dream workflow, interpretation, AI describe) ---
# https://platform.deepseek.com
VITE_DEEPSEEK_API_KEY=

# --- Optional: daily per-user limits (integers; defaults shown; 0 disables) ---
# Limits reset at midnight UTC.
# VITE_AI_LIMIT_CHAT=30
# VITE_AI_LIMIT_EXTRACT=10
# VITE_AI_LIMIT_INTERPRET=20
# VITE_AI_LIMIT_DESCRIBE=10
