rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    /** Public dreams, or the signed-in owner reading their own dream. */
    function dreamDataReadable(d) {
      return (d.keys().hasAll(['isPublic']) && d.isPublic == true)
        || (isAuthenticated() && d.keys().hasAll(['userId']) && d.userId == request.auth.uid);
    }

    function dreamReadableById(dreamId) {
      return exists(/databases/$(database)/documents/dreams/$(dreamId))
        && dreamDataReadable(get(/databases/$(database)/documents/dreams/$(dreamId)).data);
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    match /dreams/{dreamId} {
      allow read: if dreamDataReadable(resource.data);

      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;

      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;

      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /notes/{noteId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /comments/{commentId} {
      allow read: if resource.data.keys().hasAll(['dreamId'])
        && dreamReadableById(resource.data.dreamId);

      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['dreamId'])
        && dreamReadableById(request.resource.data.dreamId);

      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;

      allow delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid
        || (
          resource.data.keys().hasAll(['dreamId'])
          && exists(/databases/$(database)/documents/dreams/$(resource.data.dreamId))
          && get(/databases/$(database)/documents/dreams/$(resource.data.dreamId)).data.userId == request.auth.uid
        )
      );
    }

    match /likes/{likeId} {
      allow read: if resource.data.keys().hasAll(['dreamId'])
        && dreamReadableById(resource.data.dreamId);

      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['dreamId'])
        && dreamReadableById(request.resource.data.dreamId);

      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /favorites/{favoriteId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /friendRequests/{requestId} {
      allow read: if isAuthenticated() && (
        resource.data.fromUserId == request.auth.uid || resource.data.toUserId == request.auth.uid
      );
      allow create: if isAuthenticated() && request.resource.data.fromUserId == request.auth.uid;
      allow update, delete: if isAuthenticated() && (
        resource.data.fromUserId == request.auth.uid || resource.data.toUserId == request.auth.uid
      );
    }

    match /friends/{friendId} {
      allow read, write: if isAuthenticated() && (
        resource.data.userId1 == request.auth.uid || resource.data.userId2 == request.auth.uid
      );
      allow create: if isAuthenticated() && (
        request.resource.data.userId1 == request.auth.uid || request.resource.data.userId2 == request.auth.uid
      );
    }

    match /aiUsage/{docId} {
      function isOwnAiUsageDocId() {
        return isAuthenticated() &&
          docId.matches('^' + request.auth.uid + '_[0-9]{4}-[0-9]{2}-[0-9]{2}$');
      }
      allow read: if isOwnAiUsageDocId();
      allow create: if isOwnAiUsageDocId() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwnAiUsageDocId() && resource.data.userId == request.auth.uid;
    }
  }
}
